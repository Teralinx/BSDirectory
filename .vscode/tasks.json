{
    "tasks": [
        {
            "type": "shell",
            "label": "make",
            "command": "${config:cmake_root}/bin/cmake",
            "args": [
                "-S",
                "${config:source_root}",
                "-B",
                "${config:build_root}",
                "-G",
                "Unix Makefiles",
                "-DCMAKE_BUILD_TYPE=Debug",
                "-DCMAKE_C_COMPILER=${config:mingw_root}/bin/gcc.exe",
                "-DCMAKE_CXX_COMPILER=${config:mingw_root}/bin/g++.exe",
                "-DCMAKE_RC_COMPILER=${config:mingw_root}/bin/windres.exe",
                "-DCMAKE_CXX_FLAGS=\"-g3 -Wall -Wextra -Wpedantic -Wno-c++98-compat -Wno-padded\""
            ]
        },
        {
            "type": "shell",
            "label": "build",
            "dependsOn": [
                "make"
            ],
            "command": "${config:cmake_root}/bin/cmake.exe",
            "args": [
                "--build",
                "${config:build_root}"
            ]
        }
    ],
    "version": "2.0.0"
}