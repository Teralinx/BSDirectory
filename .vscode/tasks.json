{
    "tasks": [
        {
            "type": "shell",
            "label": "make",
            "command": "${config:cmake_exe}",
            "args": [
                "-S",
                "${config:source_root}",
                "-B",
                "${config:build_root}",
                "-G",
                "Unix Makefiles",
                "-DCMAKE_BUILD_TYPE=Debug",
                "-DCMAKE_C_COMPILER=${config:gcc_exe}",
                "-DCMAKE_CXX_COMPILER=${config:g++_exe}",
                "-DCMAKE_RC_COMPILER=${config:rc_exe}",
                "-DCMAKE_CXX_FLAGS=\"${config:cxx_flags}\"",
                "-DCMAKE_MAKE_PROGRAM=\"${config:make_exe}\"",
                "-DCMAKE_PREFIX_PATH=\"${config:qt_root};${CMAKE_PREFIX_PATH}\""
            ]
        },
        {
            "type": "shell",
            "label": "build",
            "dependsOn": [
                "make"
            ],
            "command": "${config:cmake_exe}",
            "args": [
                "--build",
                "${config:build_root}"
            ]
        }
    ],
    "version": "2.0.0"
}